{
  "env": {
    "browser": true,
    "es6": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "extends": "eslint:recommended",
  "globals": {
    "validatePhone": "readonly",
    "getElement": "readonly",
    "getSelectedPlan": "readonly",
    "resetPlanSelection": "readonly",
    "escapeHtml": "readonly",
    "scrollToElement": "readonly",
    "navigateTo": "readonly",
    "showToast": "readonly",
    "APP_CONFIG": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "no-redeclare": "off"
  }
}
